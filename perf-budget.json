{
  "defaultProfile": "docs",
  "profiles": {
    "docs": {
      "description": "Server-rendered documentation route budget.",
      "assertions": [
        "lcp <= 2500",
        "long_tasks <= 2",
        "tbt <= 150",
        "js_total_kb <= 160"
      ]
    },
    "playground": {
      "description": "Interactive parser playground shell and WASM bootstrap.",
      "assertions": [
        "lcp <= 3000",
        "long_tasks <= 2",
        "tbt <= 450",
        "js_total_kb <= 160",
        "network_kb <= 5200"
      ]
    }
  },
  "routes": [
    {"url": "/", "profile": "docs"},
    {"url": "/docs/getting-started", "profile": "docs"},
    {"url": "/docs/performance", "profile": "docs"},
    {"url": "/playground", "profile": "playground"}
  ]
}
